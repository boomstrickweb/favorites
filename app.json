{
  "expo": {
    "name": "fav♡rites",
    "slug": "favorites-social",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/favorites-logo.png",
    "scheme": "favoritessocial",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.favoritessocial.app",
      "supportsTablet": true,
      "icon": "./assets/images/favorites-logo.png",
      "splash": {
        "image": "./assets/images/favorites-splash-screen-white.jpeg",
        "tabletImage": "./assets/images/favorites-splash-screen-white.jpeg",
        "dark": {
          "image": "./assets/images/favorites-splash-screen-dark.jpeg",
          "tabletImage": "./assets/images/favorites-splash-screen-dark.jpeg"
        },
        "resizeMode": "contain",
        "backgroundColor": "#ffffff"
      }
    },
    "android": {
      "package": "com.favoritessocial.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/favorites-logo.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "splash": {
        "image": "./assets/images/favorites-splash-screen-white.jpeg",
        "dark": {
          "image": "./assets/images/favorites-splash-screen-dark.jpeg"
        },
        "resizeMode": "contain",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff",
          "image": "./assets/images/favorites-splash-screen-white.jpeg",
          "dark": {
            "image": "./assets/images/favorites-splash-screen-dark.jpeg",
            "backgroundColor": "#000000"
          },
          "imageWidth": 200
        }
      ],
      "expo-font",
      "expo-secure-store",
      "expo-sharing",
      "expo-image"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "updates": {
      "url": "https://u.expo.dev/2e1a5a42-66c5-44cb-8409-34c2785af3df"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2e1a5a42-66c5-44cb-8409-34c2785af3df"
      }
    }
  }
}
